# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/

# --- Environments ---
.venv/
venv/
.env

# --- Disk discipline (50 GB budget): never commit heavy artifacts ---
# Models / checkpoints / adapters
*.safetensors
*.ckpt
*.pt
*.bin
checkpoints/
adapters/
outputs/

# Datasets / benchmark assets (LIBERO, LIBERO-Plus ~6.4GB) and third-party source installs
data/libero/
data/libero_plus/
data/raw/
third_party/

# deploy.py local cache dir (off-AutoDL default; on AutoDL caches live under /root/autodl-tmp)
.vcr-cache/

# Rollout videos — only a HANDFUL of curated demo clips are kept (see analysis/demos/)
*.mp4
*.gif
*.avi
!analysis/demos/*.mp4
!analysis/demos/*.gif

# Keep eval *summaries* (small CSV/JSON) but ignore bulky per-episode dumps
analysis/runs/**/episodes/

# --- OS / editor ---
.DS_Store
*.swp
.idea/
.vscode/
